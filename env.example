# ══════════════════════════════════════════════════
#  GEOFENCE TRACKER — ENVIRONMENT CONFIGURATION
#  Save this file as: .env  (in the same folder as server.js)
# ══════════════════════════════════════════════════

# ── MongoDB ────────────────────────────────────────
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/geofence
# OR MongoDB Atlas:
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/geofence

# ── Gmail Email ────────────────────────────────────
# Your Gmail address
EMAIL_USER=nirmal991744@gmail.com

# ⚠️  IMPORTANT: Wrap your App Password in double quotes!
# The password has spaces — quotes prevent dotenv from breaking it.
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS="elih xbwo sjaq vgxe"

# ── Admin Notifications ────────────────────────────
# This email gets notified every time a user enters/exits a zone
ADMIN_EMAIL=nirmal991744@gmail.com

# ── Server Port ────────────────────────────────────
PORT=3000

# ══════════════════════════════════════════════════
#  GMAIL SETUP CHECKLIST
# ══════════════════════════════════════════════════
#  ✅ 1. Gmail 2-Step Verification must be ON
#         → https://myaccount.google.com/security
#
#  ✅ 2. Generate an App Password (NOT your real password)
#         → https://myaccount.google.com/apppasswords
#         → Select app: Mail, Device: Other → name it "Geofence"
#         → Copy the 16-char password shown
#
#  ✅ 3. Paste the password with QUOTES in this file:
#         EMAIL_PASS="abcd efgh ijkl mnop"
#
#  ✅ 4. Test email works: 
#         Open browser → http://localhost:3000/api/test-email?to=yourmail@gmail.com
# ══════════════════════════════════════════════════
